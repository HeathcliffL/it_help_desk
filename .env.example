# Copy this file to .env to customize local settings.
# .env is git-ignored so anything you put here stays local.
#
# Nothing here is required. The app runs with sensible defaults if .env
# is absent or empty.

# Flask session secret. Any random string works for local dev.
SECRET_KEY=replace-this-secret

# Optional: override the database.
# By default the app uses SQLite (helpdesk.db in the project root).
# Uncomment and edit to point at a Postgres server instead:
# DATABASE_URL=postgresql://user:password@localhost:5432/campus_helpdesk
